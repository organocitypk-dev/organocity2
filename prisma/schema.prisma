generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(cuid())
  handle           String   @unique
  title            String
  description      String?
  descriptionHtml  String?
  price            Float
  compareAtPrice   Float?
  sku              String?
  inventory        Int      @default(0)
  availableForSale Boolean  @default(true)
  status           String   @default("ACTIVE")
  seoTitle         String?
  seoDescription   String?
  images           Json     @default("[]")
  featuredImage    String?
  productType      String?
  categoryId       String?
  subcategoryId    String?
  vendor           String   @default("OrganoCity")
  tags             Json     @default("[]")
  collectionIds    Json     @default("[]")
  isFeatured       Boolean  @default(false)
  displayOrder     Int      @default(9999)
  details          Json     @default("[]")
  certificates     Json     @default("[]")
  packagingSizes   Json     @default("[]")
  netWeight        String?
  origin           String?
  shelfLife        String?
  faqs             Json     @default("[]")
  wholesaleQuoteEnabled Boolean @default(false)
  color            String?
  size             String?
  storage          String?
  ram              String?
  processor        String?
  condition        String?
  specifications   Json     @default("{}")
  customAttributes Json     @default("{}")
  variations       ProductVariation[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([displayOrder])
}

model ProductVariation {
  id               String   @id @default(cuid())
  name             String
  value            String   @default("")
  description      String?
  price            Float
  compareAtPrice   Float?
  sku              String?
  stock            Int      @default(0)
  images           Json     @default("[]")
  color            String?
  size             String?
  storage          String?
  ram              String?
  processor        String?
  condition        String?
  specifications   Json     @default("{}")
  customAttributes Json     @default("{}")
  active           Boolean  @default(true)
  isDefault        Boolean  @default(false)
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId])
}

model Collection {
  id              String   @id @default(cuid())
  handle          String   @unique
  title           String
  description     String?
  descriptionHtml String?
  image           String?
  seoTitle        String?
  seoDescription  String?
  productHandles  Json     @default("[]")
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress Json        // { line1, line2, city, state, pincode, country }
  items           Json        // array of { productId, title, price, quantity, image }
  subtotal        Float
  shippingCost    Float       @default(0)
  tax             Float       @default(0)
  total           Float
  discount        Float       @default(0)
  couponCode      String?
  paymentMethod   String      @default("pending")
  paymentStatus   String      @default("pending")
  paymentProofUrl String?
  transactionReference String?
  confirmationEmailSentAt DateTime?
  orderStatus     String      @default("pending")
  notes           String?
  trackingNumber  String?
  trackingUrl     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Inquiry {
  id              String      @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String
  message         String
  type            String      @default("contact")
  status          String      @default("unread")
  adminNote       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Category {
  id              String      @id @default(cuid())
  name            String      @unique
  slug            String      @unique
  description     String?
  image           String?
  parentId        String?
  order           Int         @default(0)
  featured        Boolean     @default(false)
  seoTitle        String?
  seoDescription  String?
  productIds      Json        @default("[]")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model BlogPost {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  excerpt         String?
  content         String?
  featuredImage   String?
  categoryId      String?
  author          String
  status          String      @default("draft")
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?
  tags            Json        @default("[]")
  views           Int         @default(0)
  isFeatured      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Review {
  id              String      @id @default(cuid())
  authorName      String
  authorEmail     String?
  authorImage     String?
  rating          Int         @default(5)
  content         String
  productId       String?
  productHandle   String?
  isFeatured      Boolean     @default(false)
  status          String      @default("pending") // pending, approved, rejected
  isVerifiedPurchase Boolean  @default(false)
  helpfulCount    Int         @default(0)
  images          Json        @default("[]")
  adminNote       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([productId])
  @@index([status])
  @@index([isFeatured])
}

model Certificate {
  id            String      @id @default(cuid())
  name          String
  image         String
  description   String?
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  isVerifiedBy  Boolean    @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model HeroSlide {
  id                String   @id @default(cuid())
  imageUrl          String
  mobileImageUrl    String?
  imageAlt          String
  eyebrow           String
  title             String
  titleHighlight    String
  description       String
  ctaPrimaryLabel   String?
  ctaPrimaryHref    String?
  ctaSecondaryLabel String?
  ctaSecondaryHref  String?
  isActive          Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model HomepageSection {
  id              String      @id @default(cuid())
  sectionKey      String      @unique
  title           String?
  subtitle        String?
  content         Json?
  order           Int         @default(0)
  isActive        Boolean     @default(true)
  image           String?
  updatedAt       DateTime    @updatedAt
}

enum VideoPlatform {
  YOUTUBE
  TIKTOK
  FACEBOOK
  INSTAGRAM
}

enum VideoPlacement {
  HOMEPAGE
  ABOUT
  VIDEOS_PAGE
}

enum VideoFormat {
  LANDSCAPE
  VERTICAL
}

model Video {
  id              String         @id @default(cuid())
  title           String
  description     String?
  thumbnail       String?
  videoUrl        String
  embedUrl        String?
  platform        VideoPlatform
  placement       VideoPlacement @default(VIDEOS_PAGE)
  format          VideoFormat    @default(LANDSCAPE)
  buttonText      String?
  buttonUrl       String?
  featured        Boolean        @default(false)
  active          Boolean        @default(true)
  displayOrder    Int            @default(0)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([platform])
  @@index([placement])
  @@index([featured])
  @@index([active])
  @@index([displayOrder])
}

model NavigationMenu {
  id              String      @id @default(cuid())
  location        String      @unique
  items           Json
  updatedAt       DateTime    @updatedAt
}

model MediaAsset {
  id              String      @id @default(cuid())
  filename        String
  url             String
  publicId        String
  type            String
  size            Int
  alt             String?
  uploadedBy      String?
  usedIn          String?
  referenceId     String?
  createdAt       DateTime    @default(now())
}
